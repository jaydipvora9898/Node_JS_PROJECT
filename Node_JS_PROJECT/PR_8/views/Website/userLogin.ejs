<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Login - Meesho</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-color: #A1036D;
            --secondary-color: #F05A94;
            --accent-color: #FF9EC0;
            --light-bg: #FFF5F9;
            --dark-text: #333333;
            --light-text: #666666;
            --white: #ffffff;
            --border-color: #FFD9E6;
            --success-color: #2ECC71;
            --card-shadow: 0 2px 15px rgba(236, 0, 140, 0.15);
            --card-hover-shadow: 0 5px 20px rgba(236, 0, 140, 0.2);
            --transition: all 0.3s ease;
            --border-radius: 12px;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        body {
            background: var(--light-bg);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            color: var(--dark-text);
        }
        
        .login-container {
            width: 100%;
            max-width: 450px;
        }
        
        .logo-container {
            text-align: center;
            margin-bottom: 25px;
        }
        
        .logo {
            font-weight: 700;
            font-size: 2.5rem;
            color: var(--primary-color);
            text-decoration: none;
            display: inline-block;
            margin-bottom: 10px;
        }
        
        .tagline {
            color: var(--light-text);
            font-size: 1rem;
            margin-bottom: 10px;
        }
        
        .login-card {
            background: var(--white);
            border-radius: var(--border-radius);
            overflow: hidden;
            box-shadow: var(--card-shadow);
            transition: var(--transition);
            border: 1px solid var(--border-color);
        }
        
        .login-card:hover {
            box-shadow: var(--card-hover-shadow);
        }
        
        .card-header {
            background: var(--primary-color);
            color: var(--white);
            text-align: center;
            padding: 1.5rem;
            border-bottom: none;
        }
        
        .card-header h3 {
            margin: 0;
            font-weight: 600;
            font-size: 1.5rem;
        }
        
        .card-body {
            padding: 2rem;
        }
        
        .form-group {
            margin-bottom: 1.2rem;
            position: relative;
        }
        
        .form-group label {
            font-weight: 500;
            margin-bottom: 0.5rem;
            color: var(--dark-text);
            display: block;
            font-size: 0.9rem;
        }
        
        .form-control {
            padding: 0.8rem 1rem;
            border-radius: 8px;
            border: 1px solid var(--border-color);
            transition: var(--transition);
            background: #FFFBFD;
            color: var(--dark-text);
            width: 100%;
            font-size: 0.95rem;
        }
        
        .form-control:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(236, 0, 140, 0.2);
            outline: none;
        }
        
        .input-icon {
            position: absolute;
            right: 15px;
            top: 40px;
            color: var(--light-text);
        }
        
        .btn-login {
            background:var(--primary-color);
            color: var(--white);
            border: none;
            padding: 0.9rem;
            font-weight: 600;
            font-size: 1rem;
            border-radius: 8px;
            transition: var(--transition);
            width: 100%;
            cursor: pointer;
            margin-top: 0.5rem;
        }
        
        .btn-login:hover {
            background: linear-gradient(135deg, var(--secondary-color) 0%, var(--primary-color) 100%);
            transform: translateY(-2px);
            color: white;
            box-shadow: 0 4px 10px rgba(236, 0, 140, 0.3);
        }
        
        .btn-login:active {
            transform: translateY(0);
        }
        
        .password-toggle {
            cursor: pointer;
            transition: var(--transition);
        }
        
        .password-toggle:hover {
            color: var(--primary-color);
        }
        
        .additional-options {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 1.2rem 0;
        }
        
        .form-check-input:checked {
            background-color: var(--primary-color);
            border-color: var(--primary-color);
        }
        
        .forgot-password {
            color: var(--primary-color);
            text-decoration: none;
            font-size: 0.9rem;
            transition: var(--transition);
        }
        
        .forgot-password:hover {
            text-decoration: underline;
            color: var(--secondary-color);
        }
        
        .register-link {
            text-align: center;
            margin-top: 1.5rem;
            color: var(--light-text);
            font-size: 0.9rem;
        }
        
        .register-link a {
            color: var(--primary-color);
            text-decoration: none;
            font-weight: 600;
            transition: var(--transition);
        }
        
        .register-link a:hover {
            text-decoration: underline;
        }
        
        .social-login {
            margin-top: 1.8rem;
            text-align: center;
        }
        
        .divider {
            display: flex;
            align-items: center;
            margin: 1.5rem 0;
            color: var(--light-text);
            font-size: 0.8rem;
        }
        
        .divider::before,
        .divider::after {
            content: "";
            flex: 1;
            border-bottom: 1px solid var(--border-color);
        }
        
        .divider::before {
            margin-right: 0.5rem;
        }
        
        .divider::after {
            margin-left: 0.5rem;
        }
        
        .social-buttons {
            display: flex;
            justify-content: center;
            gap: 12px;
        }
        
        .social-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background: #FFFBFD;
            border: 1px solid var(--border-color);
            transition: var(--transition);
            color: var(--dark-text);
            font-size: 1.1rem;
        }
        
        .social-btn:hover {
            background: var(--primary-color);
            color: white;
            transform: translateY(-2px);
            border-color: var(--primary-color);
        }
        
        @media (max-width: 768px) {
            .card-body {
                padding: 1.5rem;
            }
            
            .login-container {
                padding: 10px;
            }
            
            .logo {
                font-size: 2rem;
            }
            
            .additional-options {
                flex-direction: column;
                align-items: flex-start;
                gap: 0.8rem;
            }
        }

        .logo {
            align-items: center;
            text-decoration: none;
        }
        
        .logo-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            background-color: var(--primary-color);
            color: white;
            border-radius: 8px;
            font-size: 1.5rem;
            font-weight: 700;
            margin-right: -7px;
        }
        
        .logo-text {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary-color);
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="logo-container">
            <a href="/webPage/home" class="logo">
                <span class="logo-icon">M</span>
                <span class="logo-text">eesho</span>
            </a>
        <div class="tagline">India's #1 Fashion Destination</div>
    </div>

        <div class="login-card">
            <div class="card-header">
                <h3><i class="fas fa-sign-in-alt me-2"></i>User Login</h3>
            </div>
            <div class="card-body">
                <form action="/webPage/userLogin" method="POST">
                    <div class="form-group">
                        <label for="email"><i class="fas fa-envelope me-1"></i> Email</label>
                        <input type="email" name="userEmail" class="form-control" placeholder="Enter your email address" required>
                        <div class="input-icon">
                            <i class="fas fa-envelope"></i>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="password"><i class="fas fa-lock me-1"></i> Password</label>
                        <input type="password" name="userPassword" id="password" class="form-control" placeholder="Enter your password" required>
                        <div class="input-icon password-toggle" onclick="togglePassword()">
                            <i class="fas fa-eye" id="passwordIcon"></i>
                        </div>
                    </div>

                    <div class="additional-options">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="rememberMe">
                            <label class="form-check-label" for="rememberMe" style="font-size: 0.9rem;">Remember me</label>
                        </div>
                        <a href="#" class="forgot-password">Forgot password?</a>
                    </div>

                    <button type="submit" class="btn btn-login">
                        <i class="fas fa-sign-in-alt me-2"></i>Login
                    </button>
                </form>

                <div class="social-login">
                    <div class="divider">Or login with</div>
                    <div class="social-buttons">
                        <a href="#" class="social-btn">
                            <i class="fab fa-google"></i>
                        </a>
                        <a href="#" class="social-btn">
                            <i class="fab fa-facebook-f"></i>
                        </a>
                        <a href="#" class="social-btn">
                            <i class="fab fa-twitter"></i>
                        </a>
                    </div>
                </div>

                <div class="register-link">
                    Don't have an account? <a href="/webPage/registerPage">Register here</a>
                </div>

                <div class="register-link">
                    <a href="/webPage/home"> Back To Home</a>

                </div>
            </div>
        </div>
    </div>

    <script>
        function togglePassword() {
            const passwordInput = document.getElementById('password');
            const passwordIcon = document.getElementById('passwordIcon');
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                passwordIcon.classList.remove('fa-eye');
                passwordIcon.classList.add('fa-eye-slash');
            } else {
                passwordInput.type = 'password';
                passwordIcon.classList.remove('fa-eye-slash');
                passwordIcon.classList.add('fa-eye');
            }
        }
    </script>
</body>
</html>