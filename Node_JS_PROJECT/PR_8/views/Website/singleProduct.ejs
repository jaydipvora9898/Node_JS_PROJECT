<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.productTitle %> - Product Details</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
    <style>
        :root {
            --primary-color: #A1036D;
            --secondary-color: #ec407a;
            --accent-color: #ff6b6b;
            --light-bg: #f5f7fa;
            --dark-text: #2d3436;
            --light-text: #7f8c8d;
            --white: #ffffff;
            --border-color: #e0e0e0;
            --success-color: #27ae60;
            --discount-color: #e74c3c;
            --card-shadow: 0 2px 10px rgba(0, 0, 0, 0.08);
            --card-hover-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #f8f9fa;
            color: var(--dark-text);
            line-height: 1.6;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 15px;
        }
        .header-auth {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.header-auth .btn-signup {
    padding: 0.5rem 1rem;
    border: 1px solid var(--primary-color);
    border-radius: 25px;
    background-color: var(--primary-color);
    color: var(--white);
    font-weight: 500;
    font-size: 0.9rem;
    cursor: pointer;
    transition: var(--transition);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

.header-auth .btn-signup:hover {
    background-color: var(--secondary-color);
    border-color: var(--secondary-color);
    color: var(--white);
    box-shadow: var(--card-hover-shadow);
}

.header-auth .user-name {
    background-color: var(--light-bg);
    color: var(--dark-text);
    border-radius: 25px;
    padding: 0.5rem 1rem;
    font-weight: 500;
    font-size: 0.9rem;
}

.user-dropdown {
    position: relative;
    display: inline-block;
}

.user-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 16px;
    color: #333;
    display: flex;
    align-items: center;
    gap: 5px;
}

.user-btn i {
    font-size: 12px;
}

.dropdown-content {
    display: none;
    position: absolute;
    right: 0;
    top: calc(100% + 2px) !important;
    background-color: #fff;
    min-width: 180px;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    padding: 10px;
    z-index: 100;
    border-radius: 5px;
}

.dropdown-content a {
    display: block;
    padding: 5px 0;
    text-decoration: none;
    color: #333;
}

.dropdown-content a:hover {
    color: #A1036D; 
}

.user-dropdown:hover .dropdown-content {
    display: block;
}
.header-right {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            padding: 0px 30px;
        }

        .header-auth, .header-icons {
            display: flex;
            align-items: center;
        }

        .user-dropdown {
            position: relative;
        }

        .user-btn {
            background-color: var(--primary-color);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 30px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 600;
            transition: var(--transition);
        }

        .user-btn:hover {
            background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));
            box-shadow: 0 4px 12px rgba(161, 3, 109, 0.3);
        }

        .dropdown-content {
            display: none;
            position: absolute;
            right: 0;
            top: calc(100% + 10px);
            background-color: var(--white);
            min-width: 280px;
            border-radius: 12px;
            box-shadow: var(--card-hover-shadow);
            z-index: 100;
            padding: 20px;
            border: 1px solid var(--border-color);
            opacity: 0;
            transform: translateY(-10px);
            transition: var(--transition);
        }

        .user-dropdown:hover .dropdown-content {
            display: block;
            opacity: 1;
            transform: translateY(0);
        }

        .dropdown-content p {
            margin-bottom: 12px;
            color: var(--dark-text);
        }

        .dropdown-content strong {
            color: var(--primary-color);
        }

        .dropdown-content hr {
            margin: 15px 0;
            border: none;
            height: 1px;
            background-color: var(--border-color);
        }

        .dropdown-content a {
            display: block;
            color: var(--dark-text);
            padding: 10px 0;
            text-decoration: none;
            transition: var(--transition);
            border-radius: 6px;
            padding-left: 10px;
        }

        .dropdown-content a:hover {
            color: var(--primary-color);
            background-color: var(--light-bg);
            padding-left: 15px;
        }

        .btn-signup {
            background-color: var(--primary-color);
            color: white;
            text-decoration: none;
            padding: 10px 25px;
            border-radius: 30px;
            font-weight: 600;
            transition: var(--transition);
        }

        .btn-signup:hover {
            background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));
            box-shadow: 0 4px 12px rgba(161, 3, 109, 0.3);
        }

        .header-icon {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-decoration: none;
            color: var(--dark-text);
            transition: var(--transition);
            padding: 8px 12px;
            border-radius: 8px;
            position: relative;
        }

        .header-icon:hover {
            color: var(--primary-color);
            background-color: var(--light-bg);
        }

        .header-icon i {
            font-size: 20px;
            margin-bottom: 4px;
        }

        .header-icon span {
            font-size: 13px;
            font-weight: 500;
        }

        .cart-count {
            position: absolute;
            top: 0;
            right: 0;
            background-color: var(--primary-color);
            color: white;
            font-size: 12px;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        .demo-content {
            max-width: 1200px;
            margin: 30px auto;
            text-align: center;
        }

        .toggle-buttons {
            margin: 20px 0;
        }

        .toggle-btn {
            background: var(--white);
            border: 2px solid var(--primary-color);
            color: var(--primary-color);
            padding: 10px 20px;
            border-radius: 6px;
            cursor: pointer;
            margin: 0 10px;
            font-weight: 600;
            transition: var(--transition);
        }

        .toggle-btn:hover {
            background: var(--primary-color);
            color: white;
        }

        h1 {
            color: var(--primary-color);
            margin-bottom: 20px;
        }

        p {
            color: var(--light-text);
            line-height: 1.6;
            margin-bottom: 20px;
        }

           
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 15px;
        }
        
        .top-header {
            background-color: var(--white);
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            position: sticky;
            top: 0;
            z-index: 100;
            padding: 10px 0;
        }
        
        .top-header .container {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        
        .logo {
            display: flex;
            align-items: center;
            text-decoration: none;
        }
        
        .logo-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            background-color: var(--primary-color);
            color: white;
            border-radius: 8px;
            font-size: 1.5rem;
            font-weight: 700;
            margin-right: 5px;
        }
        
        .logo-text {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary-color);
        }
        
        .header-center {
            flex: 1;
            max-width: 500px;
            margin: 0 20px;
        }
        
        .search-bar {
            position: relative;
            display: flex;
            align-items: center;
        }
        
        .search-bar i {
            position: absolute;
            left: 15px;
            color: var(--light-text);
            z-index: 2;
        }
        
        .search-bar input {
            width: 100%;
            padding: 10px 15px 10px 45px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            font-size: 0.9rem;
            background-color: #f5f5f5;
        }
        
        .header-right {
            display: flex;
            align-items: center;
        }
        
        .header-icons {
            display: flex;
            align-items: center;
        }
        
        .header-icon {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-left: 20px;
            text-decoration: none;
            color: var(--dark-text);
            font-size: 0.8rem;
            position: relative;
        }
        
        .header-icon i {
            font-size: 1.2rem;
            margin-bottom: 4px;
        }
        
        .cart-count {
            position: absolute;
            top: -5px;
            right: -5px;
            background-color: var(--primary-color);
            color: white;
            border-radius: 50%;
            width: 18px;
            height: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
        }

        .product-section {
            display: flex;
            flex-wrap: wrap;
            gap: 30px;
            margin: 30px 0;
        }

        .product-gallery {
            flex: 1;
            min-width: 300px;
            background: white;
            border-radius: 12px;
            padding: 20px;
            box-shadow: var(--card-shadow);
        }

        .main-image {
            width: 100%;
            height: 400px;
            object-fit: contain;
            margin-bottom: 15px;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 15px;
        }

        .thumbnail-container {
            justify-content: space-around;
            align-items: center;
            display: flex;
            gap: 10px;
             width: 450px;
            padding: 5px;
        }

        .thumbnail {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 8px;
            cursor: pointer;
            border: 2px solid transparent;
            transition: var(--transition);
        }

        .thumbnail:hover, .thumbnail.active {
            border-color: var(--primary-color);
        }

        .product-details {
            flex: 1;
            min-width: 300px;
        }

        .product-title {
            font-size: 24px;
            color: var(--dark-text);
            margin-bottom: 15px;
            font-weight: 600;
        }

        .rating {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
        }

        .stars {
            color: #ffc107;
            margin-right: 10px;
        }

        .rating-count {
            color: var(--light-text);
            font-size: 14px;
        }

        .price-container {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
            margin-bottom: 20px;
        }

        .current-price {
            font-size: 28px;
            font-weight: 700;
            color: var(--primary-color);
        }

        .original-price {
            font-size: 20px;
            color: var(--light-text);
            text-decoration: line-through;
        }

        .discount {
            background-color: var(--discount-color);
            color: white;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: 600;
        }

        .shipping-badge {
            display: inline-block;
            background-color: var(--success-color);
            color: white;
            padding: 6px 12px;
            border-radius: 4px;
            font-size: 14px;
            margin-bottom: 20px;
        }

        .product-description {
            margin-bottom: 25px;
            line-height: 1.8;
            color: var(--dark-text);
        }

        .category-info {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: 25px;
        }

        .category-item {
            display: flex;
            align-items: center;
        }

        .category-item strong {
            min-width: 120px;
            color: var(--primary-color);
        }

        .action-buttons {
            display: flex;
            gap: 15px;
            margin-top: 30px;
        }

        .btn {
            padding: 14px 28px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            border: none;
            font-size: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: white;
            flex: 2;
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));
            box-shadow: 0 5px 15px rgba(161, 3, 109, 0.3);
        }

        .btn-secondary {
            background-color: white;
            color: var(--primary-color);
            border: 2px solid var(--primary-color);
            flex: 1;
        }

        .btn-secondary:hover {
            background-color: var(--light-bg);
        }

        .btn i {
            margin-right: 8px;
        }

        .details-section {
            background: white;
            border-radius: 12px;
            padding: 25px;
            margin-bottom: 30px;
            box-shadow: var(--card-shadow);
        }

        .section-title {
            font-size: 20px;
            color: var(--primary-color);
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--border-color);
        }

        .specs-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 15px;
        }

        .spec-item {
            display: flex;
            margin-bottom: 15px;
        }

        .spec-name {
            min-width: 150px;
            color: var(--light-text);
        }

        .spec-value {
            font-weight: 500;
        }

        @media (max-width: 768px) {
            .product-section {
                flex-direction: column;
            }
            
            .action-buttons {
                flex-direction: column;
            }
            
            .specs-grid {
                grid-template-columns: 1fr;
            }
        }

        .similar-products {
            margin: 40px 0;
        }

        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .product-card {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: var(--card-shadow);
            transition: var(--transition);
        }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--card-hover-shadow);
        }

        .card-image {
            width: 100%;
            height: 200px;
            object-fit: contain;
            padding: 15px;
            border-bottom: 1px solid var(--border-color);
        }

        .card-content {
            padding: 15px;
        }

        .card-title {
            font-size: 16px;
            margin-bottom: 10px;
            height: 100%;
            overflow: hidden;
        }

        .card-price {
            color: var(--primary-color);
            font-weight: 700;
            font-size: 18px;
        }

        .card-original-price {
            color: var(--light-text);
            text-decoration: line-through;
            font-size: 14px;
            margin-left: 8px;
        }
    </style>
</head>


<body>
    <header>
        <div class="top-header">
            <div class="container">
                <div class="header-left">
                    <a href="/webPage/home" class="logo">
                        <span class="logo-icon">M</span>
                        <span class="logo-text">eesho</span>
                    </a>
                </div>
                <div class="header-center">
                    <div class="search-bar">
                        <i class="fas fa-search"></i>
                        <input type="text" placeholder="Try Saree, Kurti or Search by Product Code">
                    </div>
                </div>
                <div class="header-right">
                    <div class="header-auth">
                        <% if (session.user) { %>
                            <div class="user-dropdown" id="user-dropdown">
                                <button class="user-btn">
                                    <i class="fas fa-user"></i>
                                    <span id="user-name"><%= session.user.firstName %> <%= session.user.lastName %></span>
                                    <i class="fas fa-caret-down"></i>
                                </button>
                                <div class="dropdown-content">
                                        <a href="/webPage/userProfile"><i class="fas fa-user-circle"></i> Profile</a>
                                    <a href="/webPage/userOrders"><i class="fas fa-shopping-bag"></i> Orders</a>
                                    <a href="/webPage/logoutUser"><i class="fas fa-sign-out-alt"></i> Logout</a>
                                </div>
                            </div>
                        <% } else { %>
                            <a href="/webPage/userLogin" class="btn-signup">
                                <i class="fas fa-sign-in-alt"></i> Login
                            </a>
                        <% } %>
                    </div>
                
                    <div class="header-icons">
                        <a href="#" class="header-icon">
                            <i class="far fa-heart"></i>
                            <span>Wishlist</span>
                        </a>
                        <a href="/webPage/cart" class="header-icon">
                            <i class="fas fa-shopping-cart"></i>
                            <span>Cart</span>
                            <span class="cart-count"><%= cartCount %></span>

                        </a>
                    </div>
                </div>
                
            </div>
        </div>
    </header>

    <div class="container">
        <div class="product-section">
            <div class="product-gallery">
                <img src="<%= product.productImage %>" alt="<%= product.productTitle %>" class="main-image" id="mainImage">

                <div class="thumbnail-container">
                    <img src="<%= product.productImage %>" alt="Thumbnail 1" class="thumbnail active" onclick="changeImage(this)">
                    <img src="<%= product.productImage %>" alt="Thumbnail 1" class="thumbnail active" onclick="changeImage(this)">
                    <img src="<%= product.productImage %>" alt="Thumbnail 1" class="thumbnail active" onclick="changeImage(this)">
                    <img src="<%= product.productImage %>" alt="Thumbnail 1" class="thumbnail active" onclick="changeImage(this)">
                </div>
            </div>

            <div class="product-details">
                <h1 class="product-title"><%= product.productTitle %></h1>

                <div class="rating">
                    <div class="stars">
                        <% for (let i = 1; i <= 5; i++) { %>
                            <i class="fas fa-star"></i>
                        <% } %>
                    </div>
                    <span class="rating-count">(100 reviews)</span>
                </div>

                <div class="price-container">
                    <span class="current-price">₹<%= product.productPrice %></span>
                    <span class="original-price">₹<%= (product.productPrice * 1.5).toFixed(0) %></span>
                    <span class="discount"> <%= product.productDescount %>%  OFF</span>
                </div>

                <div class="shipping-badge">
                    <i class="fas fa-shipping-fast"></i> Free Delivery
                </div>

                <p class="product-description"><%= product.productDesc %></p>

                <div class="category-info">
                    <div class="category-item">
                        <strong>Category:</strong> <span><%= product.categoryName ? product.categoryName.categoryName : 'N/A' %></span>
                    </div>
                    <div class="category-item">
                        <strong>Sub Category:</strong> <span><%= product.subCategoryName ? product.subCategoryName.subCategoryName : 'N/A' %></span>
                    </div>
                    <div class="category-item">
                        <strong>Extra Category:</strong> <span><%= product.extraCategoryName ? product.extraCategoryName.extraCategoryName : 'N/A' %></span>
                    </div>
                </div>

                <div class="action-buttons">
                    <% if (session.user) { %>
                        <form action="/webPage/cart/add-to-cart" method="POST">
                            <input type="hidden" name="productId" value="<%= product._id %>">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-shopping-cart"></i> Add to Cart
                            </button>
                        </form>
                    <% } else { %>
                        <a href="/webPage/userLogin" class="btn btn-primary">
                            <i class="fas fa-shopping-cart"></i> Add to Cart
                        </a>
                    <% } %>

                    <button class="btn btn-secondary">
                        <i class="far fa-heart"></i> Wishlist
                    </button>
                </div>
            </div>
        </div>

        <div class="details-section">
            <h2 class="section-title">Product Details</h2>
            <div class="specs-grid">
                <div class="spec-item">
                    <span class="spec-name">Material:</span>
                    <span class="spec-value">Polyester</span>
                </div>
                <div class="spec-item">
                    <span class="spec-name">Sleeve Length:</span>
                    <span class="spec-value">Full Sleeve</span>
                </div>
                <div class="spec-item">
                    <span class="spec-name">Pattern:</span>
                    <span class="spec-value">Floral Print</span>
                </div>
                <div class="spec-item">
                    <span class="spec-name">Fit:</span>
                    <span class="spec-value">Regular</span>
                </div>
                <div class="spec-item">
                    <span class="spec-name">Neck:</span>
                    <span class="spec-value">Round Neck</span>
                </div>
                <div class="spec-item">
                    <span class="spec-name">Wash Care:</span>
                    <span class="spec-value">Machine Wash</span>
                </div>
            </div>
        </div>

        <div class="similar-products">
            <h2 class="section-title">Related Products</h2>
            
<div class="products-grid">
    <% relatedProducts.forEach((related) => { %>
        <div class="product-card">
            <img src="<%= related.productImage %>" alt="<%= related.productTitle %>" class="card-image">

            <div class="card-content">
                <h3 class="card-title"><%= related.productTitle %></h3>
                <div>
                    <span class="card-price">₹<%= related.productPrice %></span>
                    <span class="card-original-price">₹<%= (related.productPrice * 1.5).toFixed(0) %></span>
                </div>
                <a href="/webPage/product/<%= related._id %>" class="btn btn-primary">
                    View Product
                </a>
            </div>
        </div>
    <% }); %>

    <% if (relatedProducts.length === 0) { %>
        <p>No related products found.</p>
    <% } %>
</div>

        </div>
    </div>

    <script>
        function changeImage(element) {
            document.getElementById('mainImage').src = element.src;
            document.querySelectorAll('.thumbnail').forEach(thumb => {
                thumb.classList.remove('active');
            });
            element.classList.add('active');
        }
    </script>
</body>

</html>
