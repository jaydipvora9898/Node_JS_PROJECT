<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register Account - Meesho</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-color: #A1036D;
            --secondary-color: #F05A94;
            --accent-color: #FF9EC0;
            --light-bg: #FFF5F9;
            --dark-text: #333333;
            --light-text: #666666;
            --white: #ffffff;
            --border-color: #FFD9E6;
            --success-color: #2ECC71;
            --card-shadow: 0 2px 15px rgba(236, 0, 140, 0.15);
            --card-hover-shadow: 0 5px 20px rgba(236, 0, 140, 0.2);
            --transition: all 0.3s ease;
            --border-radius: 12px;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        body {
            background: var(--light-bg);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            color: var(--dark-text);
        }
        
        .register-container {
            width: 100%;
            max-width: 800px;
        }
        
        .logo-container {
            text-align: center;
            margin-bottom: 20px;
        }
        
        .logo {
            font-weight: 700;
            font-size: 2.5rem;
            color: var(--primary-color);
            text-decoration: none;
            display: inline-block;
            margin-bottom: 10px;
        }
        
        .tagline {
            color: var(--light-text);
            font-size: 1rem;
            margin-bottom: 30px;
        }
        
        .register-card {
            background: var(--white);
            border-radius: var(--border-radius);
            overflow: hidden;
            box-shadow: var(--card-shadow);
            transition: var(--transition);
            border: 1px solid var(--border-color);
        }
        
        .register-card:hover {
            box-shadow: var(--card-hover-shadow);
        }
        
        .card-header {
            background:  var(--primary-color) ;
            color: var(--white);
            text-align: center;
            padding: 1.5rem;
            border-bottom: none;
        }
        
        .card-header h3 {
            margin: 0;
            font-weight: 600;
            font-size: 1.5rem;
        }
        
        .card-body {
            padding: 2rem;
        }
        
        .form-group {
            margin-bottom: 1.2rem;
            position: relative;
        }
        
        .form-group label {
            font-weight: 500;
            margin-bottom: 0.5rem;
            color: var(--dark-text);
            display: block;
            font-size: 0.9rem;
        }
        
        .form-control {
            padding: 0.8rem 1rem;
            border-radius: 8px;
            border: 1px solid var(--border-color);
            transition: var(--transition);
            background: #FFFBFD;
            color: var(--dark-text);
            width: 100%;
            font-size: 0.95rem;
        }
        
        .form-control:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(236, 0, 140, 0.2);
            outline: none;
        }
        
        .input-icon {
            position: absolute;
            right: 15px;
            top: 40px;
            color: var(--light-text);
        }
        
        .btn-register {
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
            color: var(--white);
            border: none;
            padding: 0.9rem;
            font-weight: 600;
            font-size: 1rem;
            border-radius: 8px;
            transition: var(--transition);
            width: 100%;
            cursor: pointer;
            margin-top: 0.5rem;
        }
        
        .btn-register:hover {
            background: var(--primary-color) ;
            transform: translateY(-2px);
            color: white;
            box-shadow: 0 4px 10px rgba(236, 0, 140, 0.3);
        }
        
        .btn-register:active {
            transform: translateY(0);
        }
        
        .password-toggle {
            cursor: pointer;
            transition: var(--transition);
        }
        
        .password-toggle:hover {
            color: var(--primary-color);
        }
        
        .login-link {
            text-align: center;
            margin-top: 1.5rem;
            color: var(--light-text);
            font-size: 0.9rem;
        }
        
        .login-link a {
            color: var(--primary-color);
            text-decoration: none;
            font-weight: 600;
            transition: var(--transition);
        }
        
        .login-link a:hover {
            text-decoration: underline;
        }
        
        .benefits {
            background: #FFF9FC;
            border-radius: 8px;
            padding: 1.5rem;
            margin-top: 1.5rem;
            border: 1px solid var(--border-color);
        }
        
        .benefits h5 {
            color: var(--primary-color);
            margin-bottom: 1rem;
            font-size: 1rem;
        }
        
        .benefit-item {
            display: flex;
            align-items: center;
            margin-bottom: 0.8rem;
            font-size: 0.9rem;
            color: var(--light-text);
        }
        
        .benefit-item i {
            color: var(--success-color);
            margin-right: 10px;
            font-size: 1rem;
        }
        
        @media (max-width: 768px) {
            .card-body {
                padding: 1.5rem;
            }
            
            .register-container {
                padding: 10px;
            }
            
            .logo {
                font-size: 2rem;
            }
        }
        .logo {
            /* display: flex; */
            align-items: center;
            text-decoration: none;
        }
        
        .logo-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            background-color: var(--primary-color);
            color: white;
            border-radius: 8px;
            font-size: 1.5rem;
            font-weight: 700;
            margin-right: -7px;
        }
        
        .logo-text {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary-color);
        }
    </style>
</head>
<body>
    <div class="register-container">
        <div class="logo-container">
                <a href="/webPage/home" class="logo">
                    <span class="logo-icon">M</span>
                    <span class="logo-text">eesho</span>
                </a>
            <div class="tagline">India's #1 Fashion Destination</div>
        </div>
        
        <div class="register-card">
            <div class="card-header">
                <h3><i class="fas fa-user-plus me-2"></i>Create Your Account</h3>
            </div>
            <div class="card-body">
                <form action="/webPage/registerUser" method="POST">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="firstName"><i class="fas fa-user me-1"></i> First Name</label>
                                <input type="text" name="userFirstName" class="form-control" placeholder="Enter your first name" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="lastName"><i class="fas fa-user me-1"></i> Last Name</label>
                                <input type="text" name="userLastName" class="form-control" placeholder="Enter your last name" required>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="email"><i class="fas fa-envelope me-1"></i> Email</label>
                        <input type="email" name="userEmail" class="form-control" placeholder="Enter your email address" required>
                    </div>

                    <div class="form-group">
                        <label for="password"><i class="fas fa-lock me-1"></i> Password</label>
                        <input type="password" name="userPassword" id="password" class="form-control" placeholder="Create a strong password" required>
                        <div class="input-icon password-toggle" onclick="togglePassword()">
                            <i class="fas fa-eye" id="passwordIcon"></i>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="gender"><i class="fas fa-venus-mars me-1"></i> Gender</label>
                                <select name="userGender" class="form-control" required>
                                    <option value="">-- Select Gender --</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                    <option value="Other">Other</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="contact"><i class="fas fa-phone me-1"></i> Contact</label>
                                <input type="text" name="userContact" class="form-control" placeholder="Your phone number" required>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-register">
                        <i class="fas fa-user-plus me-2"></i>Register Now
                    </button>
                </form>

                <div class="login-link">
                    Already have an account? <a href="/webPage/userLogin">Login here</a>
                </div>
                <span class="login-link">
                  <a href="/webPage/home">Back To Home</a>
                </span>
                
                <div class="benefits">
                    <h5><i class="fas fa-gift me-2"></i>Benefits of creating an account:</h5>
                    <div class="benefit-item">
                        <i class="fas fa-check-circle"></i>
                        <span>Get exclusive discounts and offers</span>
                    </div>
                    <div class="benefit-item">
                        <i class="fas fa-check-circle"></i>
                        <span>Fast and easy checkout process</span>
                    </div>
                    <div class="benefit-item">
                        <i class="fas fa-check-circle"></i>
                        <span>Track your orders easily</span>
                    </div>
                    <div class="benefit-item">
                        <i class="fas fa-check-circle"></i>
                        <span>Access your order history</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function togglePassword() {
            const passwordInput = document.getElementById('password');
            const passwordIcon = document.getElementById('passwordIcon');
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                passwordIcon.classList.remove('fa-eye');
                passwordIcon.classList.add('fa-eye-slash');
            } else {
                passwordInput.type = 'password';
                passwordIcon.classList.remove('fa-eye-slash');
                passwordIcon.classList.add('fa-eye');
            }
        }
    </script>
</body>
</html>