<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meesho Clone - Affordable Shopping</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<style>
          :root {
            --primary-color: #A1036D;
            --secondary-color: #ec407a;
            --accent-color: #ff6b6b;
            --light-bg: #f5f7fa;
            --dark-text: #2d3436;
            --light-text: #7f8c8d;
            --white: #ffffff;
            --border-color: #e0e0e0;
            --success-color: #27ae60;
            --discount-color: #e74c3c;
            --card-shadow: 0 2px 10px rgba(0, 0, 0, 0.08);
            --card-hover-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            --transition: all 0.3s ease;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #f8f9fa;
            color: var(--dark-text);
            line-height: 1.6;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 15px;
        }
        .header-auth {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.header-auth .btn-signup {
    padding: 0.5rem 1rem;
    border: 1px solid var(--primary-color);
    border-radius: 25px;
    background-color: var(--primary-color);
    color: var(--white);
    font-weight: 500;
    font-size: 0.9rem;
    cursor: pointer;
    transition: var(--transition);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

.header-auth .btn-signup:hover {
    background-color: var(--secondary-color);
    border-color: var(--secondary-color);
    color: var(--white);
    box-shadow: var(--card-hover-shadow);
}

.header-auth .user-name {
    background-color: var(--light-bg);
    color: var(--dark-text);
    border-radius: 25px;
    padding: 0.5rem 1rem;
    font-weight: 500;
    font-size: 0.9rem;
}

.user-dropdown {
    position: relative;
    display: inline-block;
}

.user-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 16px;
    color: #333;
    display: flex;
    align-items: center;
    gap: 5px;
}

.user-btn i {
    font-size: 12px;
}

.dropdown-content {
    display: none;
    position: absolute;
    right: 0;
    top: calc(100% + 2px) !important;
    background-color: #fff;
    min-width: 180px;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    padding: 10px;
    z-index: 100;
    border-radius: 5px;
}

.dropdown-content a {
    display: block;
    padding: 5px 0;
    text-decoration: none;
    color: #333;
}

.dropdown-content a:hover {
    color: #A1036D; 
}

.user-dropdown:hover .dropdown-content {
    display: block;
}
.header-right {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            padding: 0px 30px;
        }

        .header-auth, .header-icons {
            display: flex;
            align-items: center;
        }

        .user-dropdown {
            position: relative;
        }

        .user-btn {
            background-color: var(--primary-color);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 30px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 600;
            transition: var(--transition);
        }

        .user-btn:hover {
            background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));
            box-shadow: 0 4px 12px rgba(161, 3, 109, 0.3);
        }

        .dropdown-content {
            display: none;
            position: absolute;
            right: 0;
            top: calc(100% + 10px);
            background-color: var(--white);
            min-width: 280px;
            border-radius: 12px;
            box-shadow: var(--card-hover-shadow);
            z-index: 100;
            padding: 20px;
            border: 1px solid var(--border-color);
            opacity: 0;
            transform: translateY(-10px);
            transition: var(--transition);
        }

        .user-dropdown:hover .dropdown-content {
            display: block;
            opacity: 1;
            transform: translateY(0);
        }

        .dropdown-content p {
            margin-bottom: 12px;
            color: var(--dark-text);
        }

        .dropdown-content strong {
            color: var(--primary-color);
        }

        .dropdown-content hr {
            margin: 15px 0;
            border: none;
            height: 1px;
            background-color: var(--border-color);
        }

        .dropdown-content a {
            display: block;
            color: var(--dark-text);
            padding: 10px 0;
            text-decoration: none;
            transition: var(--transition);
            border-radius: 6px;
            padding-left: 10px;
        }

        .dropdown-content a:hover {
            color: var(--primary-color);
            background-color: var(--light-bg);
            padding-left: 15px;
        }

        .btn-signup {
            background-color: var(--primary-color);
            color: white;
            text-decoration: none;
            padding: 10px 25px;
            border-radius: 30px;
            font-weight: 600;
            transition: var(--transition);
        }

        .btn-signup:hover {
            background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));
            box-shadow: 0 4px 12px rgba(161, 3, 109, 0.3);
        }

        .header-icon {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-decoration: none;
            color: var(--dark-text);
            transition: var(--transition);
            padding: 8px 12px;
            border-radius: 8px;
            position: relative;
        }

        .header-icon:hover {
            color: var(--primary-color);
            background-color: var(--light-bg);
        }

        .header-icon i {
            font-size: 20px;
            margin-bottom: 4px;
        }

        .header-icon span {
            font-size: 13px;
            font-weight: 500;
        }

        .cart-count {
            position: absolute;
            top: 0;
            right: 0;
            background-color: var(--primary-color);
            color: white;
            font-size: 12px;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        .demo-content {
            max-width: 1200px;
            margin: 30px auto;
            text-align: center;
        }

        .toggle-buttons {
            margin: 20px 0;
        }

        .toggle-btn {
            background: var(--white);
            border: 2px solid var(--primary-color);
            color: var(--primary-color);
            padding: 10px 20px;
            border-radius: 6px;
            cursor: pointer;
            margin: 0 10px;
            font-weight: 600;
            transition: var(--transition);
        }

        .toggle-btn:hover {
            background: var(--primary-color);
            color: white;
        }

        h1 {
            color: var(--primary-color);
            margin-bottom: 20px;
        }

        p {
            color: var(--light-text);
            line-height: 1.6;
            margin-bottom: 20px;
        }

           
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 15px;
        }
        
        .top-header {
            background-color: var(--white);
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            position: sticky;
            top: 0;
            z-index: 100;
            padding: 10px 0;
        }
        
        .top-header .container {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        
        .logo {
            display: flex;
            align-items: center;
            text-decoration: none;
        }
        
        .logo-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            background-color: var(--primary-color);
            color: white;
            border-radius: 8px;
            font-size: 1.5rem;
            font-weight: 700;
            margin-right: 5px;
        }
        
        .logo-text {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary-color);
        }
        
        .header-center {
            flex: 1;
            max-width: 500px;
            margin: 0 20px;
        }
        
        .search-bar {
            position: relative;
            display: flex;
            align-items: center;
        }
        
        .search-bar i {
            position: absolute;
            left: 15px;
            color: var(--light-text);
            z-index: 2;
        }
        
        .search-bar input {
            width: 100%;
            padding: 10px 15px 10px 45px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            font-size: 0.9rem;
            background-color: #f5f5f5;
        }
        
        .header-right {
            display: flex;
            align-items: center;
        }
        
        .header-icons {
            display: flex;
            align-items: center;
        }
        
        .header-icon {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-left: 20px;
            text-decoration: none;
            color: var(--dark-text);
            font-size: 0.8rem;
            position: relative;
        }
        
        .header-icon i {
            font-size: 1.2rem;
            margin-bottom: 4px;
        }
        
        .cart-count {
            position: absolute;
            top: -5px;
            right: -5px;
            background-color: var(--primary-color);
            color: white;
            border-radius: 50%;
            width: 18px;
            height: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
        }

         /* Responsive Styles */
         @media (max-width: 768px) {
            .top-header .container {
                flex-wrap: wrap;
            }
            
            .header-center {
                order: 3;
                margin: 10px 0 0;
                max-width: 100%;
            }
            
            .products-grid {
                grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
                gap: 15px;
            }
            
            .categories-wrapper {
                min-width: 700px;
            }
        }
        
        @media (max-width: 576px) {
            .header-icon span {
                display: none;
            }
            
            .category-item {
                min-width: 60px;
            }
            
            .category-item img {
                width: 35px;
                height: 35px;
            }
            
            .category-item span {
                font-size: 0.7rem;
            }
        }


</style>
<body>
    <div class="top-header">
        <div class="container">
            <div class="header-left">
                <a href="/webPage/home" class="logo">
                    <span class="logo-icon">M</span>
                    <span class="logo-text">eesho</span>
                </a>
            </div>
            <div class="header-center">
                <div class="search-bar">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Try Saree, Kurti or Search by Product Code">
                </div>
            </div>
            <div class="header-right">
                <div class="header-auth">
                    <% if (session.user) { %>
                        <div class="user-dropdown" id="user-dropdown">
                            <button class="user-btn">
                                <i class="fas fa-user"></i>
                                <span id="user-name"><%= session.user.firstName %> <%= session.user.lastName %></span>
                                <i class="fas fa-caret-down"></i>
                            </button>
                            <div class="dropdown-content">
                                    <a href="/webPage/userProfile"><i class="fas fa-user-circle"></i> Profile</a>
                                <a href="/webPage/userOrders"><i class="fas fa-shopping-bag"></i> Orders</a>
                                <a href="/webPage/logoutUser"><i class="fas fa-sign-out-alt"></i> Logout</a>
                            </div>
                        </div>
                    <% } else { %>
                        <a href="/webPage/userLogin" class="btn-signup">
                            <i class="fas fa-sign-in-alt"></i> Login
                        </a>
                    <% } %>
                </div>
            
                <div class="header-icons">
                    <a href="#" class="header-icon">
                        <i class="far fa-heart"></i>
                        <span>Wishlist</span>
                    </a>
                    <a href="/webPage/cart" class="header-icon">
                        <i class="fas fa-shopping-cart"></i>
                        <span>Cart</span>
                        <span class="cart-count"><%= cartCount %></span>
                    </a>
                </div>
            </div>
            
        </div>
    </div>